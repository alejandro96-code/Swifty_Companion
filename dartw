#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
DART_BIN="$SCRIPT_DIR/flutter/bin/dart"

# Use sgoinfre for Dart cache when HOME is not explicitly set.
if [[ -z "${HOME:-}" ]]; then
  export HOME="/sgoinfre/students/${USER}/.flutter_home"
fi
if [[ -z "${PUB_CACHE:-}" ]]; then
  export PUB_CACHE="/sgoinfre/students/${USER}/.pub-cache"
fi
mkdir -p "$HOME" "$PUB_CACHE"

if [[ ! -x "$DART_BIN" ]]; then
  echo "Dart binary not found at $DART_BIN" >&2
  exit 1
fi

exec "$DART_BIN" "$@"
